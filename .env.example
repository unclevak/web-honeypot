# ════════════════════════════════════════════════════════════════════════
# Honeypot — SIEM Integration Configuration
# ════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values for integrations
# you want to enable. Leave blank or remove to disable an integration.
# ════════════════════════════════════════════════════════════════════════

# ─── Slack ───────────────────────────────────────────────────────────────
# Slack Incoming Webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── Discord ─────────────────────────────────────────────────────────────
# Discord Webhook URL
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ─── Microsoft Teams ─────────────────────────────────────────────────────
# Teams Incoming Webhook URL
# Create at: Channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=

# ─── Grafana Loki ────────────────────────────────────────────────────────
# Loki base URL (e.g., http://loki:3100)
# Logs are pushed to {LOKI_URL}/loki/api/v1/push
LOKI_URL=

# ─── Graylog (GELF HTTP) ────────────────────────────────────────────────
# Graylog GELF HTTP input URL (e.g., http://graylog:12201/gelf)
GRAYLOG_URL=

# ─── ELK / Elasticsearch ────────────────────────────────────────────────
# Elasticsearch base URL (e.g., http://elasticsearch:9200)
ELASTICSEARCH_URL=
# Index name (default: honeypot-logs)
ELASTICSEARCH_INDEX=honeypot-logs
# Optional basic auth
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=
